{
    "name": "eventsourcerer/symfony-client",
    "description": "A transport to be used with Symfony Messenger to retrieve events from EventSourcerer",
    "type": "library",
    "autoload": {
        "psr-4": {
            "EventSourcerer\\SymfonyClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EventSourcerer\\SymfonyClient\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Pear Tree Web Ltd",
            "email": "contact@peartreeweb.com"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "symfony/http-kernel": "8.0.*"
    },
    "require": {
        "php": ">=8.5",
        "symfony/dependency-injection": "8.0.*",
        "symfony/messenger": "8.0.*",
        "symfony/http-client": "8.0.*",
        "eventsourcerer/event-sourcerer-client": "dev-main",
        "symfony/console": "8.0.*",
        "symfony/process": "8.0.*",
        "eventsourcerer/common": "dev-main"
    },
    "minimum-stability": "dev"
}
